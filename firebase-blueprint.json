{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential customer lead captured during a conversation.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the lead" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "WhatsApp or Phone number" },
        "interest": { "type": "string", "description": "Product or service they are interested in" },
        "notes": { "type": "string", "description": "Additional notes from the conversation" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lead was captured" },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"], "description": "Current status of the lead" }
      },
      "required": ["phone", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A log of a conversation session with the AI agent.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string", "description": "Unique session identifier" },
        "startTime": { "type": "string", "format": "date-time", "description": "When the session started" },
        "endTime": { "type": "string", "format": "date-time", "description": "When the session ended" },
        "transcript": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "language": { "type": "string", "description": "Language used in the session" }
      },
      "required": ["sessionId", "startTime"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the DrisaTech catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "price"]
    },
    "CalendarConfig": {
      "title": "CalendarConfig",
      "description": "OAuth tokens and settings for Google Calendar integration.",
      "type": "object",
      "properties": {
        "access_token": { "type": "string" },
        "refresh_token": { "type": "string" },
        "scope": { "type": "string" },
        "token_type": { "type": "string" },
        "expiry_date": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "title": "User",
      "description": "Application user profile and permissions.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "displayName": { "type": "string" },
        "requestStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of captured customer leads"
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Logs of AI agent conversations"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog data"
    },
    "/settings/{settingId}": {
      "schema": "CalendarConfig",
      "description": "Global application settings (e.g., google_calendar)"
    }
  }
}
