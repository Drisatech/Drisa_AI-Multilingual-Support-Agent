rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leads
    // Fields: contactType (string), phone (string), email (string), notes (string), createdAt (timestamp), status (string)
    //
    // Collection: conversations
    // Fields: sessionId (string), startTime (string), endTime (string), language (string), transcript (list), summary (string), outcome (string), clientIp (string), createdAt (timestamp)
    //
    // Collection: products
    // Fields: name (string), description (string), price (string), category (string), updatedAt (timestamp)
    //
    // Collection: knowledge_sources
    // Fields: type (string), content (string), status (string), createdAt (timestamp)
    //
    // Collection: settings
    // Fields: varies by document (whatsapp, email, business)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email == "drisatech@gmail.com" && request.auth.token.email_verified == true) ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    // Users: Users can read/write their own profile, Admin can read/write all
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Leads: Public can create (for AI capture), Admin can read/write
    match /leads/{leadId} {
      allow create: if 
        request.resource.data.keys().hasAll(['contactType', 'createdAt']) &&
        isValidString('contactType', 50) &&
        (request.resource.data.contactType in ['whatsapp', 'email', 'phone']) &&
        request.resource.data.createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    // Conversations: Public can create (for AI logging), Admin can read/write
    match /conversations/{convId} {
      allow create: if 
        request.resource.data.keys().hasAll(['sessionId', 'createdAt']) &&
        isValidString('sessionId', 100) &&
        request.resource.data.createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    // Products: Publicly readable, Admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Knowledge Sources: Admin only
    match /knowledge_sources/{sourceId} {
      allow read, write: if isAdmin();
    }

    // Settings: Admin only
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
