rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leads
    // Fields: contactType, phone, email, notes, createdAt, status
    //
    // Collection: conversations
    // Fields: sessionId, startTime, endTime, language, transcript, summary, outcome, clientIp, createdAt
    //
    // Collection: products
    // Fields: name, description, price, category, updatedAt
    //
    // Collection: knowledge_sources
    // Fields: type, content, status, createdAt
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "drisatech@gmail.com");
    }

    // Leads: Public can create (for AI capture), Admin can read/write
    match /leads/{leadId} {
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    // Conversations: Public can create (for AI logging), Admin can read/write
    match /conversations/{convId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Products: Publicly readable, Admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Knowledge Sources: Admin only
    match /knowledge_sources/{sourceId} {
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
